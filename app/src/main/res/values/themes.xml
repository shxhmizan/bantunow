<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.BantuNow" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main Brand Colors -->
        <item name="colorPrimary">@color/primary_neon</item>
        <item name="colorOnPrimary">@color/bg_dark_forest</item>

        <!-- Background and Surface -->
        <item name="android:windowBackground">@color/bg_dark_forest</item>
        <item name="android:statusBarColor">@color/bg_dark_forest</item>
        <item name="colorSurface">@color/surface_pine</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/border_mint</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Outline / Border -->
        <item name="colorOutline">@color/border_mint</item>
        <item name="colorOutlineVariant">@color/border_mint</item>
    </style>

    <style name="Theme.BantuNow" parent="Base.Theme.BantuNow" />

    <!-- Style overrides for specific components -->
    <style name="WorkFormLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <style name="WorkFormChip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/surface_pine</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="chipStrokeColor">@color/border_mint</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="rippleColor">@color/primary_neon</item>
    </style>

    <style name="CircleImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>