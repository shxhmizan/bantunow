<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.BantuNow" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main Brand Colors -->
        <item name="colorPrimary">@color/brand_terracotta</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_teal</item>
        <item name="colorOnSecondary">@color/text_charcoal</item>

        <!-- Background and Surface -->
        <item name="android:windowBackground">@color/bg_creamy_white</item>
        <item name="android:statusBarColor">@color/bg_creamy_white</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="colorSurface">@color/surface_white</item>
        <item name="colorOnSurface">@color/text_charcoal</item>
        <item name="colorSurfaceVariant">@color/bg_creamy_white</item>
        <item name="colorOnSurfaceVariant">@color/text_charcoal</item>

        <!-- Outline / Border -->
        <item name="colorOutline">@color/ui_light_grey</item>
    </style>

    <style name="Theme.BantuNow" parent="Base.Theme.BantuNow" />

    <!-- Editorial Typography Styles -->
    <style name="TextAppearance.BantuNow.Heading" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_charcoal</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">serif</item> <!-- Playfair Display / Serif style -->
    </style>

    <style name="TextAppearance.BantuNow.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_charcoal</item>
        <item name="android:fontFamily">sans-serif</item> <!-- Inter / Sans-Serif style -->
    </style>

    <!-- Soft UI Card Style -->
    <style name="Widget.BantuNow.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_white</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/ui_light_grey</item>
    </style>

    <!-- Primary Action Button -->
    <style name="Widget.BantuNow.Button" parent="Widget.Material3.Button">
        <item name="materialThemeOverlay">@style/ThemeOverlay.BantuNow.Button</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.BantuNow.Button</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="ThemeOverlay.BantuNow.Button" parent="ThemeOverlay.Material3.Button">
        <item name="colorPrimary">@color/brand_terracotta</item>
        <item name="colorOnPrimary">@color/white</item>
    </style>

    <style name="ShapeAppearance.BantuNow.Button" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">16dp</item>
    </style>

    <!-- Legacy / Compatibility Style overrides -->
    <style name="WorkFormLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_charcoal</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <style name="WorkFormChip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/surface_white</item>
        <item name="android:textColor">@color/text_charcoal</item>
        <item name="chipStrokeColor">@color/ui_light_grey</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="rippleColor">@color/accent_teal</item>
    </style>

    <style name="CircleImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>