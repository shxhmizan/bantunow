<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.BantuNow" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_neon</item>
        <item name="android:windowBackground">@color/light_bg</item>
        <item name="android:statusBarColor">@color/light_bg</item>
    </style>

    <style name="Theme.BantuNow" parent="Base.Theme.BantuNow" />

    <style name="WorkFormLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/light_text_secondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <style name="WorkFormChip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/light_surface</item>
        <item name="android:textColor">@color/light_text_secondary</item>
        <item name="chipStrokeColor">@color/light_border</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="rippleColor">@color/primary_neon</item>
    </style>

    <style name="CircleImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>