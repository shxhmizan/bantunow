<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_chatbot_vignette">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/ll_chat_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="50dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_dot_gray"
            android:src="@drawable/ic_chevron_left"
            app:tint="@color/white"
            android:padding="10dp"
            android:scaleType="fitCenter"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="BantuBot AI"
            android:textColor="@color/white"
            android:fontFamily="sans-serif-medium"
            android:textSize="18sp" />

        <ImageButton
            android:id="@+id/btn_new_chat"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_dot_gray"
            android:src="@drawable/ic_edit"
            app:tint="@color/white"
            android:padding="10dp"
            android:scaleType="fitCenter"/>
    </LinearLayout>

    <!-- Center Content -->
    <LinearLayout
        android:id="@+id/ll_greeting"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/ll_chat_header"
        app:layout_constraintBottom_toTopOf="@id/container_input">

        <ImageView
            android:id="@+id/iv_ai_logo"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_robot"
            app:tint="@color/accent_teal" />

            <TextSwitcher
                android:id="@+id/ts_greeting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginHorizontal="40dp" />

            <!-- Suggestion Chips -->
            <HorizontalScrollView
                android:id="@+id/hsv_suggestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:scrollbars="none"
                android:paddingHorizontal="24dp"
                android:clipToPadding="false">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_suggest_job"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Find a job"
                        app:cornerRadius="20dp"
                        app:backgroundTint="#1AFFFFFF"
                        android:textColor="@color/white"
                        android:layout_marginEnd="8dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_suggest_price"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fair pay for cleaning?"
                        app:cornerRadius="20dp"
                        app:backgroundTint="#1AFFFFFF"
                        android:textColor="@color/white"
                        android:layout_marginEnd="8dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_suggest_points"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="How points work?"
                        app:cornerRadius="20dp"
                        app:backgroundTint="#1AFFFFFF"
                        android:textColor="@color/white"
                        android:layout_marginEnd="8dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_suggest_leaderboard"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/suggest_leaderboard"
                        app:cornerRadius="20dp"
                        app:backgroundTint="#1AFFFFFF"
                        android:textColor="@color/white"
                        android:layout_marginEnd="8dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_suggest_balance"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/suggest_balance"
                        app:cornerRadius="20dp"
                        app:backgroundTint="#1AFFFFFF"
                        android:textColor="@color/white"/>
                </LinearLayout>
            </HorizontalScrollView>

    </LinearLayout>

    <!-- Chat Area -->
    <ScrollView
        android:id="@+id/scroll_chat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/ll_chat_header"
        app:layout_constraintBottom_toTopOf="@id/container_input">

        <LinearLayout
            android:id="@+id/ll_chat_messages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp" />
    </ScrollView>

    <!-- Input Bar -->
    <LinearLayout
        android:id="@+id/container_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="120dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="64dp"
            app:cardCornerRadius="32dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1A1A1E"
            app:strokeWidth="1dp"
            app:strokeColor="#2A2A2E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_star"
                    app:tint="@color/text_secondary_grey" />

                <EditText
                    android:id="@+id/et_chat_input"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Ask BantuBot..."
                    android:textColorHint="#80FFFFFF"
                    android:paddingHorizontal="16dp"
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:maxLines="3"
                    android:inputType="textMultiLine"/>

                <ImageButton
                    android:id="@+id/btn_send_floating"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_dot_gray"
                    android:src="@drawable/ic_send"
                    app:tint="@color/white"
                    android:scaleType="fitCenter"
                    android:padding="10dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>