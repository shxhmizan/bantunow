<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light_grey">

    <WebView
        android:id="@+id/mapWebView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Glassmorphism Sticky Header -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/ll_top_bar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/glass_white_80"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="50dp"
            android:paddingBottom="20dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tv_greeting"
                    style="@style/TextAppearance.BantuNow.Heading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BantuNow"
                    android:textSize="28sp"
                    android:textColor="@color/brand_dark" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_insights"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:checked="true"
                    android:text="Insights"
                    android:textColor="@color/text_secondary_grey"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium" />
            </RelativeLayout>

            <LinearLayout
                android:id="@+id/insightContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Smart Insight Card (Soft UI) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/surface_white"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/ui_light_grey">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_robot"
                                app:tint="@color/brand_dark" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="SMART INSIGHT"
                                    android:textColor="@color/text_secondary_grey"
                                    android:textSize="10sp"
                                    android:fontFamily="sans-serif-black"
                                    android:letterSpacing="0.1" />

                                <TextView
                                    android:id="@+id/tv_insight_desc"
                                    style="@style/TextAppearance.BantuNow.Body"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Finding best jobs for you..."
                                    android:textStyle="bold"
                                    android:textSize="15sp"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <include
                    android:id="@+id/statTotal"
                    layout="@layout/item_map_stat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <include
                        android:id="@+id/miniActive"
                        layout="@layout/item_insight_mini" />

                    <include
                        android:id="@+id/miniAverage"
                        layout="@layout/item_insight_mini" />

                    <include
                        android:id="@+id/miniPopular"
                        layout="@layout/item_insight_mini" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_filter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="180dp"
        android:src="@drawable/ic_list"
        app:tint="@color/white"
        app:backgroundTint="@color/accent_teal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:fabSize="normal"
        app:elevation="8dp" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_my_location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="110dp"
        android:src="@drawable/ic_location"
        app:tint="@color/white"
        app:backgroundTint="@color/accent_coral"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:fabSize="normal"
        app:elevation="8dp" />

</androidx.constraintlayout.widget.ConstraintLayout>