<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_creamy_white"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="100dp">

        <LinearLayout
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_chevron_right"
                android:rotation="180"
                app:tint="@color/text_charcoal" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Back"
                android:textColor="@color/text_charcoal"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Workflow Indicator -->
        <LinearLayout
            android:id="@+id/ll_workflow_indicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="4">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <View
                    android:id="@+id/v_step1"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@drawable/bg_circle_filled"
                    android:backgroundTint="@color/accent_teal" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Posted"
                    android:textSize="10sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <View
                android:id="@+id/v_line1"
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_weight="0.1"
                android:layout_marginTop="10dp"
                android:background="@color/ui_light_grey" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <View
                    android:id="@+id/v_step2"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@drawable/bg_circle_filled"
                    android:backgroundTint="@color/ui_light_grey" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Accepted"
                    android:textSize="10sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <View
                android:id="@+id/v_line2"
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_weight="0.1"
                android:layout_marginTop="10dp"
                android:background="@color/ui_light_grey" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <View
                    android:id="@+id/v_step3"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@drawable/bg_circle_filled"
                    android:backgroundTint="@color/ui_light_grey" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Done"
                    android:textSize="10sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <View
                android:id="@+id/v_line3"
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_weight="0.1"
                android:layout_marginTop="10dp"
                android:background="@color/ui_light_grey" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <View
                    android:id="@+id/v_step4"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@drawable/bg_circle_filled"
                    android:backgroundTint="@color/ui_light_grey" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Paid"
                    android:textSize="10sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/tvStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_rounded"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="ONGOING"
                android:textColor="@color/accent_coral_faded"
                android:textSize="10sp"
                android:fontFamily="sans-serif-black"
                app:backgroundTint="@color/ui_light_grey" />
            <TextView
                android:id="@+id/tvRoleBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_input_rounded"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="YOU ARE DOER"
                android:textColor="@color/text_charcoal"
                android:textSize="10sp"
                android:fontFamily="sans-serif-black"
                app:backgroundTint="@color/ui_light_grey" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTaskTitle"
            style="@style/TextAppearance.BantuNow.Heading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Task Title"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/tvTaskDesc"
            style="@style/TextAppearance.BantuNow.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Task description goes here."
            android:textColor="@color/text_secondary_grey"
            android:textSize="15sp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTaskImage"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="24dp"
            android:visibility="gone"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">
            <ImageView
                android:id="@+id/ivTaskImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />
        </com.google.android.material.card.MaterialCardView>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:columnCount="2"
            android:rowCount="2">

            <!-- Card Pay -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/ui_light_grey"
                app:cardBackgroundColor="@color/surface_white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PAYMENT"
                        android:textColor="@color/text_secondary_grey"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-black" />
                    <TextView
                        android:id="@+id/tvTaskPay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RM 0"
                        android:textColor="@color/accent_coral_faded"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card Owner -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/ui_light_grey"
                app:cardBackgroundColor="@color/surface_white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ASSIGNER"
                        android:textColor="@color/text_secondary_grey"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-black" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">
                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/iv_owner_avatar"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_user"
                            app:shapeAppearanceOverlay="@style/CircleImage"
                            app:strokeWidth="0dp" />
                        <TextView
                            android:id="@+id/tvTaskOwner"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Unknown"
                            android:textColor="@color/text_charcoal"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:ellipsize="end"
                            android:maxLines="1" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card Phone -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/ui_light_grey"
                app:cardBackgroundColor="@color/surface_white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PHONE"
                        android:textColor="@color/text_secondary_grey"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-black" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_phone"
                            app:tint="@color/accent_teal" />
                        <TextView
                            android:id="@+id/tvTaskPhoneNo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="-"
                            android:textColor="@color/text_charcoal"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card Distance -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/ui_light_grey"
                app:cardBackgroundColor="@color/surface_white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DISTANCE"
                        android:textColor="@color/text_secondary_grey"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-black" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_location"
                            app:tint="@color/accent_teal" />
                        <TextView
                            android:id="@+id/tvTaskDistance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="0 km away"
                            android:textColor="@color/text_charcoal"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </GridLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            android:weightSum="2">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCall"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="Call"
                android:textColor="@color/text_charcoal"
                app:cornerRadius="16dp"
                app:backgroundTint="@color/ui_light_grey"
                app:icon="@drawable/ic_phone"
                app:iconTint="@color/text_charcoal" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWhatsapp"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="WhatsApp"
                android:textColor="@color/text_charcoal"
                app:cornerRadius="16dp"
                app:backgroundTint="@color/ui_light_grey"
                app:icon="@drawable/ic_send"
                app:iconTint="@color/text_charcoal" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnComplete"
            style="@style/Widget.BantuNow.Button"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="16dp"
            android:text="JOB DONE"
            android:textSize="17sp"
            android:textStyle="bold"
            app:icon="@drawable/ic_list"
            app:iconGravity="textStart"
            app:iconPadding="12dp" />

    </LinearLayout>
</ScrollView>