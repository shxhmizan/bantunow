<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark_forest"
    android:scrollbars="none"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bagi Kerja"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <!-- Subtitle with Neon Mint Accent -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Buat Tugasan Baru "
                android:textColor="@color/primary_neon"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_briefcase"
                app:tint="@color/primary_neon" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Isikan maklumat tugasan untuk dipaparkan di peta."
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="24dp" />

        <!-- 1. Category Chip Group -->
        <TextView
            style="@style/WorkFormLabel"
            android:text="Jenis Tugasan" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/cg_job_types"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="4dp"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                style="@style/WorkFormChip"
                android:text="Pertukangan" />
            <com.google.android.material.chip.Chip
                style="@style/WorkFormChip"
                android:text="Pembersihan" />
            <com.google.android.material.chip.Chip
                style="@style/WorkFormChip"
                android:text="Penghantaran" />
            <com.google.android.material.chip.Chip
                style="@style/WorkFormChip"
                android:text="Baik Pulih" />
            <com.google.android.material.chip.Chip
                style="@style/WorkFormChip"
                android:text="Buruh Kasar" />
            <com.google.android.material.chip.Chip
                style="@style/WorkFormChip"
                android:text="Bantuan Kecemasan" />
            <com.google.android.material.chip.Chip
                style="@style/WorkFormChip"
                android:text="Lain-lain" />
        </com.google.android.material.chip.ChipGroup>

        <!-- 2. Task Title Input -->
        <TextView
            style="@style/WorkFormLabel"
            android:text="Tajuk" />

        <EditText
            android:id="@+id/et_task_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="@drawable/bg_form_input"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:hint="cth: Pasang Meja IKEA"
            android:inputType="text"
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />

        <!-- 3. Task Description Input -->
        <TextView
            style="@style/WorkFormLabel"
            android:text="Penerangan" />

        <EditText
            android:id="@+id/et_task_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="4"
            android:gravity="top|start"
            android:padding="16dp"
            android:background="@drawable/bg_form_input"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:hint="Jelaskan tugasan anda..."
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />

        <!-- 4. Gaji & Phone Side-by-Side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    style="@style/WorkFormLabel"
                    android:text="Gaji (RM)" />

                <EditText
                    android:id="@+id/et_task_pay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:background="@drawable/bg_form_input"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:hint="25"
                    android:textSize="14sp"
                    android:inputType="number" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    style="@style/WorkFormLabel"
                    android:text="No. Telefon" />

                <EditText
                    android:id="@+id/et_task_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:background="@drawable/bg_form_input"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:hint="012-345 6789"
                    android:textSize="14sp"
                    android:inputType="phone" />
            </LinearLayout>
        </LinearLayout>

        <!-- 5. Dashed Image Upload (Optional) -->
        <TextView
            style="@style/WorkFormLabel"
            android:text="Gambar (Opsional)" />

        <LinearLayout
            android:id="@+id/layout_upload_image"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_dashed_border"
            android:layout_marginBottom="20dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_camera"
                app:tint="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Klik untuk muat naik"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- 6. Dashed Location Selector -->
        <TextView
            style="@style/WorkFormLabel"
            android:text="Lokasi" />

        <LinearLayout
            android:id="@+id/layout_get_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="16dp"
            android:background="@drawable/bg_dashed_border"
            android:layout_marginBottom="28dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_location"
                app:tint="@color/text_secondary"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dapatkan Lokasi Saya"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- 7. Bottom Submit Button -->
        <Button
            android:id="@+id/btn_submit_task"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/primary_neon"
            android:textColor="@color/bg_dark_forest"
            android:text="Hantar Tugasan"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="16dp"
            app:icon="@drawable/ic_send"
            app:iconGravity="textEnd"
            app:iconPadding="8dp"
            app:iconTint="@color/bg_dark_forest"
            app:cornerRadius="12dp" />

    </LinearLayout>
</ScrollView>
