<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:scrollbars="none"
    android:padding="24dp"
    android:paddingTop="48dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_chevron_right"
                android:rotation="180"
                app:tint="@color/text_secondary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="@string/back"
                android:textColor="@color/text_secondary"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Title Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_give_job"
            android:textColor="?attr/colorOnBackground"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fill in the task details to display on map."
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="24dp" />

        <!-- 2. Task Title Input -->
        <TextView
            style="@style/WorkFormLabel"
            android:text="@string/task_title" />

        <EditText
            android:id="@+id/et_task_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="@drawable/bg_input_rounded"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="@color/text_secondary"
            android:hint="e.g. IKEA Table Assembly"
            android:inputType="text"
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />

        <!-- 3. Task Description Input -->
        <TextView
            style="@style/WorkFormLabel"
            android:text="@string/task_desc" />

        <EditText
            android:id="@+id/et_task_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="4"
            android:gravity="top|start"
            android:padding="16dp"
            android:background="@drawable/bg_input_rounded"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="@color/text_secondary"
            android:hint="Describe your task..."
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />

        <!-- 4. Gaji & Phone Side-by-Side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    style="@style/WorkFormLabel"
                    android:text="@string/task_pay" />

                <EditText
                    android:id="@+id/et_task_pay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:background="@drawable/bg_input_rounded"
                    android:textColor="?attr/colorOnSurface"
                    android:textColorHint="@color/text_secondary"
                    android:hint="25"
                    android:textSize="14sp"
                    android:inputType="number" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    style="@style/WorkFormLabel"
                    android:text="@string/task_phone" />

                <EditText
                    android:id="@+id/et_task_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:background="@drawable/bg_input_rounded"
                    android:textColor="?attr/colorOnSurface"
                    android:textColorHint="@color/text_secondary"
                    android:hint="012-345 6789"
                    android:textSize="14sp"
                    android:inputType="phone" />
            </LinearLayout>
        </LinearLayout>

        <!-- 6. Dashed Location Selector -->
        <TextView
            style="@style/WorkFormLabel"
            android:text="Location" />

        <LinearLayout
            android:id="@+id/layout_get_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="16dp"
            android:background="@drawable/bg_dashed_border"
            android:layout_marginBottom="28dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_location"
                app:tint="@color/text_secondary"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/get_location"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- 7. Bottom Submit Button -->
        <Button
            android:id="@+id/btn_submit_task"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/primary_neon"
            android:textColor="@color/bg_dark_forest"
            android:text="@string/submit_task"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="16dp"
            app:icon="@drawable/ic_send"
            app:iconGravity="textEnd"
            app:iconPadding="8dp"
            app:iconTint="@color/bg_dark_forest"
            app:cornerRadius="12dp" />

    </LinearLayout>
</ScrollView>