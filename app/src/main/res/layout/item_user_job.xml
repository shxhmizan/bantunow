<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Status Chips and Price Row -->
        <LinearLayout
            android:id="@+id/ll_status_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_status_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_rounded"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="OPEN"
                android:textColor="@color/accent_teal"
                android:textSize="10sp"
                android:fontFamily="sans-serif-black"
                app:backgroundTint="@color/bg_light_grey" />

            <TextView
                android:id="@+id/tv_role_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_input_rounded"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="POSTED"
                android:textColor="@color/text_charcoal"
                android:textSize="10sp"
                android:fontFamily="sans-serif-black"
                app:backgroundTint="@color/ui_light_grey" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_job_pay"
                style="@style/TextAppearance.BantuNow.Heading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RM 69"
                android:textColor="@color/accent_coral_faded"
                android:textSize="18sp" />
        </LinearLayout>

        <!-- Main Content Area (Text Left, Image Right) -->
        <TextView
            android:id="@+id/tv_job_title"
            style="@style/TextAppearance.BantuNow.Body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="12dp"
            android:text="Garden Lamp Wiring"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/card_image_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ll_status_row" />

        <TextView
            android:id="@+id/tv_job_desc"
            style="@style/TextAppearance.BantuNow.Body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="12dp"
            android:text="Want to install new ceiling fan..."
            android:textColor="@color/text_secondary_grey"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintEnd_toStartOf="@+id/card_image_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_job_title" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_image_container"
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/bg_light_grey"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ll_status_row">
            <ImageView
                android:id="@+id/iv_job_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/bg_form_input" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/ll_distance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_job_desc">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_location"
                app:tint="@color/text_secondary_grey" />

            <TextView
                android:id="@+id/tv_job_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="140.4 km"
                android:textColor="@color/text_secondary_grey"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- User Info Footer -->
        <LinearLayout
            android:id="@+id/ll_user_info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="12dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/ll_actions"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ll_distance">

            <LinearLayout
                android:id="@+id/ll_assigner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Assigner: "
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary_grey" />
                <TextView
                    android:id="@+id/tv_assigner_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_charcoal" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_accepter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_accepter_avatar"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_user"
                    app:shapeAppearanceOverlay="@style/CircleImage" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tv_accepter_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Performer Name"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_charcoal" />
                    <TextView
                        android:id="@+id/tv_accepter_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5.0 ★"
                        android:textSize="10sp"
                        android:textColor="@color/brand_terracotta" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageButton
                android:id="@+id/btn_delete_job"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_delete"
                android:visibility="gone"
                app:tint="@color/accent_coral_faded" />

            <ImageButton
                android:id="@+id/btn_edit_job"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_edit"
                android:visibility="gone"
                app:tint="@color/text_charcoal" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
